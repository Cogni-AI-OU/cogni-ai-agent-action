{
  "aliveStatusCodes": [200, 206, 405],
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://localhost"
    },
    {
      "pattern": "^http://127.0.0.1"
    },
    {
      "pattern": "^https://127.0.0.1"
    },
    {
      "pattern": "^http://example.com"
    },
    {
      "pattern": "^https://example.com"
    },
    {
      "pattern": "^https://github.com/org/repo"
    },
    {
      "pattern": "^https://github.com/MiniZinc/MiniZincIDE/releases/download/"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "\\$\\{\\{ env\\.MINIZINC_VERSION \\}\\}",
      "replacement": "2.9.3"
    }
  ],
  "retryCount": 3,
  "retryOn429": true,
  "timeout": "10s"
}
