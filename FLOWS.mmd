flowchart TD
    %% --------------------------------------------------------
    %% 1. Cogni AI Agent (action.yml)
    %% --------------------------------------------------------
    subgraph Flow_Cogni_AI_Agent ["1. Cogni AI Agent (action.yml)"]
        direction TB
        A1([Trigger Events]) --> A2["Check Conditions<br/>Evaluates event type and /co, /cogni, /review, /brainstorm mentions.<br/>Determines effective agent."]
        A2 -->|If run=true| A3["Wait for Concurrent Runs<br/>Polls older workflow runs to prevent race conditions."]
        A3 --> A4["Resolve Prompt<br/>Extracts issue/PR body and appends rerun notes."]
        A4 --> A5["Checkout Repositories<br/>Clones cogni-ai-agents, instructions, and skills for context."]
        A5 --> A6["Install GH Models<br/>Sets up GitHub Models extension (if enabled)."]
        A6 --> A7["Convert Permissions<br/>Merges default and agent-specific tool permissions into JSON."]
        A7 --> A8["Run OpenCode<br/>Executes anomalyco/opencode/github with extensive config<br/>(skills, MCP, instructions)."]
        A8 --> A9(["Post-Run<br/>Writes markdown summary and prints logs if failed."])
    end

    %% --------------------------------------------------------
    %% 2. OpenCode Agent (opencode/action.yml)
    %% --------------------------------------------------------
    subgraph Flow_OpenCode_Agent ["2. OpenCode Agent (opencode/action.yml)"]
        direction TB
        O1([Trigger Events]) --> O2["Check Conditions<br/>Evaluates event type and /oc, /opencode, /review mentions.<br/>Determines effective agent."]
        O2 -->|If run=true| O3["Wait for Concurrent Runs<br/>Polls older workflow runs to prevent race conditions."]
        O3 --> O4["Resolve Prompt<br/>Extracts issue/PR body and appends rerun notes."]
        O4 --> O5["Convert Permissions<br/>Merges default and agent-specific tool permissions into JSON."]
        O5 --> O6["Run OpenCode<br/>Executes anomalyco/opencode/github with standard config<br/>(without external repos)."]
        O6 --> O7(["Post-Run<br/>Writes markdown summary and prints logs if failed."])
    end

    %% --------------------------------------------------------
    %% 3. AI Inference (ai-inference/action.yml)
    %% --------------------------------------------------------
    subgraph Flow_AI_Inference ["3. AI Inference (ai-inference/action.yml)"]
        direction TB
        I1([Trigger Events]) --> I2["Check Conditions<br/>Evaluates push, issue, PR events and /ai mentions.<br/>Defaults to cogni-ai-architect."]
        I2 -->|If run=true| I3["Wait for Concurrent Runs<br/>Polls older workflow runs to prevent race conditions."]
        I3 --> I4["Checkout Agents<br/>Clones cogni-ai-agents to load system prompts."]
        I4 --> I5["Resolve Prompt<br/>Extracts issue/PR body for inference."]
        I5 --> I6["Resolve System Prompt<br/>Matches the requested agent to its .agent.md file."]
        I6 --> I7["Run AI Inference<br/>Executes actions/ai-inference@v2 with optional GitHub MCP."]
        I7 --> I8(["Post-Run<br/>Writes markdown summary."])
    end