flowchart TD
    %% --------------------------------------------------------
    %% 1. Cogni AI Agent (action.yml)
    %% --------------------------------------------------------
    subgraph Flow_Cogni_AI_Agent ["1. Cogni AI Agent (action.yml)"]
        direction TB
        A1([Trigger Events]) --> A2{Check conditions}
        A2 -- "run=true" --> A3["Wait for concurrent runs"]
        A2 -- "run=false" --> A_EndSkip([Action Skipped])
        
        A3 --> A4["Resolve prompt"]
        A4 --> A5["Checkout Repositories<br/>(agents, instructions, skills)"]
        
        A5 -- "gh-models-enabled=true" --> A6["Install gh-models extension"]
        A5 -- "default" --> A7["Convert permissions to JSON"]
        A6 --> A7
        
        A7 --> A8["Run opencode"]
        
        A8 --> A9(["Write response to summary<br/>(on success)"])
        A8 --> A10["Print logs (on failure/cancelled)"]
    end

    %% --------------------------------------------------------
    %% 2. OpenCode Agent (opencode/action.yml)
    %% --------------------------------------------------------
    subgraph Flow_OpenCode_Agent ["2. OpenCode Agent (opencode/action.yml)"]
        direction TB
        O1([Trigger Events]) --> O2["Run opencode"]
        O2 --> O3(["anomalyco/opencode/github@v1.4.3"])
    end

    %% --------------------------------------------------------
    %% 3. AI Inference (ai-inference/action.yml)
    %% --------------------------------------------------------
    subgraph Flow_AI_Inference ["3. AI Inference (ai-inference/action.yml)"]
        direction TB
        I1([Trigger Events]) --> I2{Check conditions}
        I2 -- "run=true" --> I3["Wait for concurrent runs"]
        I2 -- "run=false" --> I_EndSkip([Action Skipped])
        
        I3 --> I4["Checkout cogni-ai-agents"]
        I4 --> I5["Resolve prompt"]
        I5 --> I6["Resolve system prompt file"]
        I6 --> I7["Run AI Inference"]
        I7 --> I8(["Write response to summary<br/>(on success)"])
    end
